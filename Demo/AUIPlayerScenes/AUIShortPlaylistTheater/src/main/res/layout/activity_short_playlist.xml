<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1C1D22"
    android:orientation="vertical">

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/top_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:itemIconTint="@color/selector_playlist_bottom"
        app:itemTextAppearanceActive="@style/bottom_playlist_title_active"
        app:itemTextAppearanceInactive="@style/bottom_playlist_title_inactive"
        app:itemTextColor="@color/selector_playlist_bottom"
        app:menu="@menu/short_playlist_menu" />

    <FrameLayout
        android:id="@+id/v_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>